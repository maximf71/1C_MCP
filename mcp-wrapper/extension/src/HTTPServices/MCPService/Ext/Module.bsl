// ── Вспомогательные функции ──────────────────────────────────

Функция РазобратьJSON(СтрокаJSON)
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
    Результат = ПрочитатьJSON(ЧтениеJSON);
    ЧтениеJSON.Закрыть();
    Возврат Результат;
КонецФункции

Функция ПреобразоватьЗначениеПараметра(Знач Значение)
    // Значения query-параметров приходят из JSON строками. Если строка имеет ISO-формат
    // даты ("ГГГГ-ММ-ДД" или "ГГГГ-ММ-ДДTчч:мм:сс"), приводим её к типу Дата — иначе
    // виртуальные таблицы (.Остатки(&Дата, ...)) дают "Несоответствие типов (Параметр номер 1)".
    // Нестроковые значения и строки иного вида возвращаются без изменений; при неудаче
    // разбора возвращается исходная строка (безопасный откат к прежнему поведению).
    Если ТипЗнч(Значение) <> Тип("Строка") Тогда
        Возврат Значение;
    КонецЕсли;

    Длина = СтрДлина(Значение);
    РазделителиДаты = (Сред(Значение, 5, 1) = "-") И (Сред(Значение, 8, 1) = "-");
    ЭтоДата = (Длина = 10) И РазделителиДаты;
    ЭтоДатаВремя = (Длина >= 19) И РазделителиДаты
        И (Сред(Значение, 11, 1) = "T" ИЛИ Сред(Значение, 11, 1) = " ")
        И (Сред(Значение, 14, 1) = ":") И (Сред(Значение, 17, 1) = ":");

    Если НЕ (ЭтоДата ИЛИ ЭтоДатаВремя) Тогда
        Возврат Значение;
    КонецЕсли;

    Если ЭтоДата Тогда
        СтрокаДаты = Значение + "T00:00:00";
    Иначе
        СтрокаДаты = СтрЗаменить(Лев(Значение, 19), " ", "T");
    КонецЕсли;

    Попытка
        Возврат XMLЗначение(Тип("Дата"), СтрокаДаты);
    Исключение
        Возврат Значение;
    КонецПопытки;
КонецФункции

Функция СформироватьJSON(Значение)
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Значение);
    Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция ОтветJSON(Значение)
    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СформироватьJSON(Значение));
    Возврат Ответ;
КонецФункции

Функция ОтветОшибка(КодСостояния, ТекстОшибки)
    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СформироватьJSON(Новый Структура("error", ТекстОшибки)));
    Возврат Ответ;
КонецФункции

Функция НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта)
    Соответствие = Новый Соответствие;
    Соответствие.Вставить("Catalog",                      Метаданные.Справочники);
    Соответствие.Вставить("Document",                     Метаданные.Документы);
    Соответствие.Вставить("Enum",                         Метаданные.Перечисления);
    Соответствие.Вставить("DataProcessor",                Метаданные.Обработки);
    Соответствие.Вставить("Report",                       Метаданные.Отчеты);
    Соответствие.Вставить("InformationRegister",          Метаданные.РегистрыСведений);
    Соответствие.Вставить("AccumulationRegister",         Метаданные.РегистрыНакопления);
    Соответствие.Вставить("AccountingRegister",           Метаданные.РегистрыБухгалтерии);
    Соответствие.Вставить("CalculationRegister",          Метаданные.РегистрыРасчета);
    Соответствие.Вставить("ChartOfAccounts",              Метаданные.ПланыСчетов);
    Соответствие.Вставить("ChartOfCharacteristicTypes",   Метаданные.ПланыВидовХарактеристик);
    Соответствие.Вставить("ChartOfCalculationTypes",      Метаданные.ПланыВидовРасчета);
    Соответствие.Вставить("ExchangePlan",                 Метаданные.ПланыОбмена);
    Соответствие.Вставить("BusinessProcess",              Метаданные.БизнесПроцессы);
    Соответствие.Вставить("Task",                         Метаданные.Задачи);
    Соответствие.Вставить("DefinedType",                  Метаданные.ОпределяемыеТипы);
    Соответствие.Вставить("Subsystem",                    Метаданные.Подсистемы);

    Коллекция = Соответствие[ТипОбъекта];
    Если Коллекция = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если ТипОбъекта = "Subsystem" Тогда
        // NEEDS REAL-1C VALIDATION: обход вложенных .Подсистемы у объекта метаданных
        // подсистемы, методы .ПолноеИмя() и .Найти() не подтверждены исходниками
        // репозитория. Имя с точкой => точное совпадение по .ПолноеИмя() (уникально).
        // Иначе собираем ВСЕ совпадения по короткому .Имя и при неоднозначности
        // возвращаем маркер (зеркалит контракт all-matches у analyze_subsystems).
        Если СтрНайти(ИмяОбъекта, ".") > 0 Тогда
            Возврат НайтиПодсистемуПоПолномуИмени(Коллекция, ИмяОбъекта);
        КонецЕсли;
        Совпадения = Новый Массив;
        СобратьПодсистемыПоКороткомуИмени(Коллекция, ИмяОбъекта, Совпадения);
        Если Совпадения.Количество() = 0 Тогда
            Возврат Неопределено;
        ИначеЕсли Совпадения.Количество() = 1 Тогда
            Возврат Совпадения[0];
        Иначе
            Маркер = Новый Структура;
            ПолныеИмена = Новый Массив;
            Для Каждого НайденнаяПодсистема Из Совпадения Цикл
                Попытка
                    ПолныеИмена.Добавить(НайденнаяПодсистема.ПолноеИмя());
                Исключение
                    ПолныеИмена.Добавить(НайденнаяПодсистема.Имя);
                КонецПопытки;
            КонецЦикла;
            Маркер.Вставить("ambiguous", ПолныеИмена);
            Возврат Маркер;
        КонецЕсли;
    КонецЕсли;

    Возврат Коллекция.Найти(ИмяОбъекта);
КонецФункции

// Рекурсивный поиск подсистемы по ПОЛНОМУ имени (уникальный ключ), включая
// вложенные подсистемы. Возвращает единственную подсистему либо Неопределено.
Функция НайтиПодсистемуПоПолномуИмени(Коллекция, ПолноеИмя)
    // NEEDS REAL-1C VALIDATION: .ПолноеИмя() и обход вложенных .Подсистемы у объекта
    // метаданных подсистемы не подтверждены исходниками этого репозитория. Каждый
    // доступ под Попытка, худший случай - подсистема не найдена, а не 500.
    Для Каждого Подсистема Из Коллекция Цикл
        Попытка
            Если Подсистема.ПолноеИмя() = ПолноеИмя Тогда
                Возврат Подсистема;
            КонецЕсли;
        Исключение
        КонецПопытки;
        Вложенная = Неопределено;
        Попытка
            Вложенная = НайтиПодсистемуПоПолномуИмени(Подсистема.Подсистемы, ПолноеИмя);
        Исключение
        КонецПопытки;
        Если Вложенная <> Неопределено Тогда
            Возврат Вложенная;
        КонецЕсли;
    КонецЦикла;
    Возврат Неопределено;
КонецФункции

// Рекурсивный сбор ВСЕХ подсистем с указанным коротким .Имя, включая вложенные.
// Собирает все совпадения (а не первое), чтобы неоднозначность коротких имён была
// видна вызывающему; при >1 совпадении вызывающий возвращает маркер ambiguous.
Функция СобратьПодсистемыПоКороткомуИмени(Коллекция, Имя, Совпадения)
    // NEEDS REAL-1C VALIDATION: обход вложенных .Подсистемы у объекта метаданных
    // подсистемы не подтверждён исходниками этого репозитория. Обход под Попытка.
    Для Каждого Подсистема Из Коллекция Цикл
        Если Подсистема.Имя = Имя Тогда
            Совпадения.Добавить(Подсистема);
        КонецЕсли;
        Попытка
            СобратьПодсистемыПоКороткомуИмени(Подсистема.Подсистемы, Имя, Совпадения);
        Исключение
        КонецПопытки;
    КонецЦикла;
    Возврат Совпадения;
КонецФункции

Функция ЕстьКоллекция(ОбъектМД, ИмяКоллекции)
    Попытка
        Значение = ОбъектМД[ИмяКоллекции];
        Возврат Истина;
    Исключение
        Возврат Ложь;
    КонецПопытки;
КонецФункции

Функция ПривестиЗначениеКJSON(Значение)
    Если Значение = Неопределено ИЛИ Значение = NULL Тогда
        Возврат "";
    ИначеЕсли ТипЗнч(Значение) = Тип("Число") ИЛИ ТипЗнч(Значение) = Тип("Булево") Тогда
        Возврат Значение;
    Иначе
        Возврат Строка(Значение);
    КонецЕсли;
КонецФункции

Функция ПолучитьОсновнуюФорму(ОбъектМД)
    МассивОсновных = Новый Массив;
    МассивОсновных.Добавить("ОсновнаяФормаОбъекта");
    МассивОсновных.Добавить("ОсновнаяФормаСписка");
    МассивОсновных.Добавить("ОсновнаяФормаВыбора");
    МассивОсновных.Добавить("ОсновнаяФорма");

    Для Каждого ИмяСвойства Из МассивОсновных Цикл
        Попытка
            ОсновнаяФорма = ОбъектМД[ИмяСвойства];
            Если ОсновнаяФорма <> Неопределено Тогда
                Возврат ОсновнаяФорма;
            КонецЕсли;
        Исключение
            Продолжить;
        КонецПопытки;
    КонецЦикла;

    Попытка
        Если ОбъектМД.Формы.Количество() > 0 Тогда
            Для Каждого ФормаМД Из ОбъектМД.Формы Цикл
                Возврат ФормаМД;
            КонецЦикла;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Неопределено;
КонецФункции

// ── Обработчики HTTP-запросов ────────────────────────────────

// GET /metadata
Функция МетаданныеGET(Запрос)
    Результат = Новый Структура;

    ИменаКоллекций = Новый Массив;
    ИменаКоллекций.Добавить("Справочники");
    ИменаКоллекций.Добавить("Документы");
    ИменаКоллекций.Добавить("Перечисления");
    ИменаКоллекций.Добавить("Обработки");
    ИменаКоллекций.Добавить("Отчеты");
    ИменаКоллекций.Добавить("РегистрыСведений");
    ИменаКоллекций.Добавить("РегистрыНакопления");
    ИменаКоллекций.Добавить("РегистрыБухгалтерии");
    ИменаКоллекций.Добавить("РегистрыРасчета");
    ИменаКоллекций.Добавить("ПланыСчетов");
    ИменаКоллекций.Добавить("ПланыВидовХарактеристик");
    ИменаКоллекций.Добавить("ПланыВидовРасчета");
    ИменаКоллекций.Добавить("ПланыОбмена");
    ИменаКоллекций.Добавить("БизнесПроцессы");
    ИменаКоллекций.Добавить("Задачи");
    ИменаКоллекций.Добавить("ОпределяемыеТипы");
    ИменаКоллекций.Добавить("ЖурналыДокументов");
    ИменаКоллекций.Добавить("Константы");
    ИменаКоллекций.Добавить("ОбщиеМодули");
    ИменаКоллекций.Добавить("ОбщиеФормы");
    ИменаКоллекций.Добавить("ОбщиеКоманды");
    ИменаКоллекций.Добавить("ОбщиеМакеты");
    ИменаКоллекций.Добавить("Роли");
    ИменаКоллекций.Добавить("Подсистемы");
    ИменаКоллекций.Добавить("РегулярныеЗадания");
    ИменаКоллекций.Добавить("ВебСервисы");
    ИменаКоллекций.Добавить("HTTPСервисы");

    Для Каждого ИмяКоллекции Из ИменаКоллекций Цикл
        Попытка
            Коллекция = Метаданные[ИмяКоллекции];
            Имена = Новый Массив;
            Для Каждого ОбъектМетаданных Из Коллекция Цикл
                Имена.Добавить(ОбъектМетаданных.Имя);
            КонецЦикла;
            Результат.Вставить(ИмяКоллекции, Имена);
        Исключение
            Продолжить;
        КонецПопытки;
    КонецЦикла;

    Возврат ОтветJSON(Результат);
КонецФункции

// GET /object/{type}/{name}
Функция ОбъектGET(Запрос)
    ТипОбъекта = Запрос.ПараметрыURL["type"];
    ИмяОбъекта = Запрос.ПараметрыURL["name"];

    ОбъектМД = НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Возврат ОтветОшибка(404, "Object not found");
    КонецЕсли;

    // Маркер неоднозначности (короткое имя Subsystem дало >1 совпадение): вернуть
    // JSON со списком полных имён {"ambiguous": [...]}, чтобы Go-сторона показала
    // сигнал уточнения вместо пустой структуры. Объект метаданных не является
    // Структурой, поэтому проверка типа надёжно отличает маркер.
    Если ТипОбъекта = "Subsystem" И ТипЗнч(ОбъектМД) = Тип("Структура") Тогда
        Возврат ОтветJSON(ОбъектМД);
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("name", ОбъектМД.Имя);
    Результат.Вставить("synonym", ОбъектМД.Синоним);

    Реквизиты = Новый Массив;
    Если ЕстьКоллекция(ОбъектМД, "Реквизиты") Тогда
        Для Каждого Реквизит Из ОбъектМД.Реквизиты Цикл
            ОписаниеРеквизита = Новый Структура;
            ОписаниеРеквизита.Вставить("name", Реквизит.Имя);
            ОписаниеРеквизита.Вставить("synonym", Реквизит.Синоним);
            ОписаниеРеквизита.Вставить("type", Строка(Реквизит.Тип));
            Реквизиты.Добавить(ОписаниеРеквизита);
        КонецЦикла;
    КонецЕсли;
    Результат.Вставить("attributes", Реквизиты);

    Если ЕстьКоллекция(ОбъектМД, "ТабличныеЧасти") Тогда
        ТЧ = Новый Массив;
        Для Каждого ТабличнаяЧасть Из ОбъектМД.ТабличныеЧасти Цикл
            ОписаниеТЧ = Новый Структура;
            ОписаниеТЧ.Вставить("name", ТабличнаяЧасть.Имя);
            РеквизитыТЧ = Новый Массив;
            Для Каждого Реквизит Из ТабличнаяЧасть.Реквизиты Цикл
                Описание = Новый Структура;
                Описание.Вставить("name", Реквизит.Имя);
                Описание.Вставить("synonym", Реквизит.Синоним);
                Описание.Вставить("type", Строка(Реквизит.Тип));
                РеквизитыТЧ.Добавить(Описание);
            КонецЦикла;
            ОписаниеТЧ.Вставить("attributes", РеквизитыТЧ);
            ТЧ.Добавить(ОписаниеТЧ);
        КонецЦикла;
        Результат.Вставить("tabularParts", ТЧ);
    КонецЕсли;

    Если ЕстьКоллекция(ОбъектМД, "Измерения") Тогда
        Измерения = Новый Массив;
        Для Каждого Измерение Из ОбъектМД.Измерения Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Измерение.Имя);
            Описание.Вставить("synonym", Измерение.Синоним);
            Описание.Вставить("type", Строка(Измерение.Тип));
            Измерения.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("dimensions", Измерения);
    КонецЕсли;

    Если ЕстьКоллекция(ОбъектМД, "Ресурсы") Тогда
        Ресурсы = Новый Массив;
        Для Каждого Ресурс Из ОбъектМД.Ресурсы Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Ресурс.Имя);
            Описание.Вставить("synonym", Ресурс.Синоним);
            Описание.Вставить("type", Строка(Ресурс.Тип));
            Ресурсы.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("resources", Ресурсы);
    КонецЕсли;

    Если ЕстьКоллекция(ОбъектМД, "ЗначенияПеречисления") Тогда
        Значения = Новый Массив;
        Для Каждого Значение Из ОбъектМД.ЗначенияПеречисления Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Значение.Имя);
            Описание.Вставить("synonym", Значение.Синоним);
            Описание.Вставить("comment", Значение.Комментарий);
            Значения.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("values", Значения);
    КонецЕсли;

    // Состав определяемого типа. Guard по ТипОбъекта, а не по наличию свойства .Тип
    // (защита от ложного срабатывания на других объектах, у которых тоже есть .Тип).
    Если ТипОбъекта = "DefinedType" Тогда
        СоставТипов = Новый Массив;
        Попытка
            // NEEDS REAL-1C VALIDATION: доступ .Тип у ОпределяемыйТип, метод .Типы()
            // у ОписаниеТипов и Метаданные.НайтиПоТипу()/ПолноеИмя() ниже подтверждены
            // офиц. документацией 1С и БСП, но не исходниками этого репозитория.
            ОписаниеТиповОбъекта = ОбъектМД.Тип;
            Для Каждого ТипЭлемента Из ОписаниеТиповОбъекта.Типы() Цикл
                // Ссылочный тип -> техническое ПолноеИмя (напр. "Справочник.Пользователи"),
                // нужное ИИ для кода и запросов. Для примитивов НайтиПоТипу возвращает
                // Неопределено, поэтому берём Строка(Тип) (напр. "Число").
                МетаОбъект = Метаданные.НайтиПоТипу(ТипЭлемента);
                Если МетаОбъект <> Неопределено Тогда
                    СоставТипов.Добавить(МетаОбъект.ПолноеИмя());
                Иначе
                    СоставТипов.Добавить(Строка(ТипЭлемента));
                КонецЕсли;
            КонецЦикла;
        Исключение
            // Защитный откат: Строка(<ОписаниеТипов>) подтверждён исходниками
            // (блоки реквизитов, измерений, ресурсов). Худший случай: пустой массив, не 500.
            Попытка
                СоставТипов = Новый Массив;
                СоставТипов.Добавить(Строка(ОбъектМД.Тип));
            Исключение
            КонецПопытки;
        КонецПопытки;
        Результат.Вставить("types", СоставТипов);
    КонецЕсли;

    // Структура подсистемы. Guard по ТипОбъекта. content = полные имена входящих
    // объектов (ОбъектМД.Состав), subsystems = дерево вложенных подсистем.
    Если ТипОбъекта = "Subsystem" Тогда
        // NEEDS REAL-1C VALIDATION: .Состав, .ПолноеИмя() у элементов состава и
        // вложенные .Подсистемы у подсистемы не подтверждены исходниками репозитория.
        // Всё защищено Попытка. Худший случай: пустые массивы, не 500.
        ПредупрежденияПодсистемы = Новый Массив;
        Состав = Новый Массив;
        Попытка
            Для Каждого ЭлементСостава Из ОбъектМД.Состав Цикл
                Попытка
                    Состав.Добавить(ЭлементСостава.ПолноеИмя());
                Исключение
                    ДобавитьПредупреждениеПодсистемы(ПредупрежденияПодсистемы, ОбъектМД, ОписаниеОшибки());
                КонецПопытки;
            КонецЦикла;
        Исключение
            ДобавитьПредупреждениеПодсистемы(ПредупрежденияПодсистемы, ОбъектМД, ОписаниеОшибки());
        КонецПопытки;
        Результат.Вставить("content", Состав);

        ДочерниеПодсистемы = Новый Массив;
        Попытка
            Для Каждого ДочерняяПодсистема Из ОбъектМД.Подсистемы Цикл
                ДочерниеПодсистемы.Добавить(ОписаниеПодсистемы(ДочерняяПодсистема, ПредупрежденияПодсистемы));
            КонецЦикла;
        Исключение
            ДобавитьПредупреждениеПодсистемы(ПредупрежденияПодсистемы, ОбъектМД, ОписаниеОшибки());
        КонецПопытки;
        Результат.Вставить("subsystems", ДочерниеПодсистемы);

        Если ПредупрежденияПодсистемы.Количество() > 0 Тогда
            Результат.Вставить("warnings", ПредупрежденияПодсистемы);
        КонецЕсли;
    КонецЕсли;

    Возврат ОтветJSON(Результат);
КонецФункции

// Добавляет нефатальное предупреждение сбора дерева подсистемы в общий
// накопитель. Формат строки: "Подсистема <имя>: <текст ошибки>". Сбор строки
// под Попытка, чтобы сама диагностика не приводила к 500. Массив передаётся по
// ссылке (как Совпадения в СобратьПодсистемыПоКороткомуИмени).
// NEEDS REAL-1C VALIDATION: доступ .Имя у подсистемы следует сиблинг-коду.
Процедура ДобавитьПредупреждениеПодсистемы(Предупреждения, ПодсистемаМД, ТекстОшибки)
    Если Предупреждения = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Попытка
        Предупреждения.Добавить("Подсистема " + ПодсистемаМД.Имя + ": " + ТекстОшибки);
    Исключение
        Попытка
            Предупреждения.Добавить("Подсистема: " + ТекстОшибки);
        Исключение
        КонецПопытки;
    КонецПопытки;
КонецПроцедуры

// Рекурсивное описание подсистемы: имя, полное имя, синоним, состав и дети.
// Массив Предупреждения (по ссылке) накапливает нефатальные ошибки сбора
// состава, полного имени и рекурсии по детям, чтобы усечение членства было
// видно потребителю, а не молча терялось (BUG-3b).
Функция ОписаниеПодсистемы(ПодсистемаМД, Предупреждения)
    // NEEDS REAL-1C VALIDATION: .Имя/.Синоним следуют сиблинг-коду, но .ПолноеИмя(),
    // .Состав + .ПолноеИмя() элементов и вложенные .Подсистемы у подсистемы
    // не подтверждены исходниками этого репозитория. Каждая часть под Попытка.
    Описание = Новый Структура;
    Описание.Вставить("name", ПодсистемаМД.Имя);
    Попытка
        Описание.Вставить("fullName", ПодсистемаМД.ПолноеИмя());
    Исключение
        Описание.Вставить("fullName", "");
        ДобавитьПредупреждениеПодсистемы(Предупреждения, ПодсистемаМД, ОписаниеОшибки());
    КонецПопытки;
    Описание.Вставить("synonym", ПодсистемаМД.Синоним);

    Состав = Новый Массив;
    Попытка
        Для Каждого ЭлементСостава Из ПодсистемаМД.Состав Цикл
            Попытка
                Состав.Добавить(ЭлементСостава.ПолноеИмя());
            Исключение
                ДобавитьПредупреждениеПодсистемы(Предупреждения, ПодсистемаМД, ОписаниеОшибки());
            КонецПопытки;
        КонецЦикла;
    Исключение
        ДобавитьПредупреждениеПодсистемы(Предупреждения, ПодсистемаМД, ОписаниеОшибки());
    КонецПопытки;
    Описание.Вставить("content", Состав);

    ДочерниеПодсистемы = Новый Массив;
    Попытка
        Для Каждого ДочерняяПодсистема Из ПодсистемаМД.Подсистемы Цикл
            ДочерниеПодсистемы.Добавить(ОписаниеПодсистемы(ДочерняяПодсистема, Предупреждения));
        КонецЦикла;
    Исключение
        ДобавитьПредупреждениеПодсистемы(Предупреждения, ПодсистемаМД, ОписаниеОшибки());
    КонецПопытки;
    Описание.Вставить("subsystems", ДочерниеПодсистемы);

    Возврат Описание;
КонецФункции

// GET /subsystems
// Возвращает { "subsystems": [<дерево подсистем>], "allObjects": [<полные имена>] }.
// subsystems  — дерево корневых подсистем (тот же ОписаниеПодсистемы, что и в /object).
// allObjects: полные имена объектов конфигурации ВСЕХ видов верхнего уровня,
//             пригодных для состава подсистемы (прикладные виды И служебные:
//             Константы, ОбщиеМодули, Роли, ОпределяемыеТипы, ПодпискиНаСобытия и др.),
//             чтобы orphans был согласован с containing (объект любого из этих видов
//             вне подсистем теперь попадает в orphans). Не входит только контейнер
//             Подсистемы. Список ниже синхронизирован с Go universeServiceKinds.
Функция ПодсистемыGET(Запрос)
    Результат = Новый Структура;

    // Единый накопитель нефатальных предупреждений: усечения дерева подсистем
    // (ОписаниеПодсистемы) и пропуски коллекций универсума сливаются в один массив
    // warnings, чтобы неполнота ответа была видна потребителю (BUG-3b).
    Предупреждения = Новый Массив;

    // Дерево корневых подсистем.
    Подсистемы = Новый Массив;
    Попытка
        Для Каждого КорневаяПодсистема Из Метаданные.Подсистемы Цикл
            Подсистемы.Добавить(ОписаниеПодсистемы(КорневаяПодсистема, Предупреждения));
        КонецЦикла;
    Исключение
        Предупреждения.Добавить("Подсистемы: " + ОписаниеОшибки());
    КонецПопытки;
    Результат.Вставить("subsystems", Подсистемы);

    // Универсум объектов, которые подсистема в принципе может содержать. Покрывает ВЕСЬ
    // набор видов верхнего уровня, пригодных для состава подсистемы: прикладные (15) И
    // служебные и прочие (27: Константы, ОбщиеМодули, Роли, ОпределяемыеТипы, ПодпискиНаСобытия,
    // Стили, ЭлементыСтиля, КритерииОтбора, Последовательности, ОбщиеРеквизиты, НумераторыДокументов,
    // ВнешниеИсточникиДанных и др.), чтобы orphans был согласован с containing. Исключения
    // среди видов верхнего уровня: Подсистемы (контейнер, а не объект состава) и Язык
    // (документально не входит в состав подсистемы; локализация).
    //
    // СИНХРОНИЗАЦИЯ: список ниже совпадает по составу видов с Go-таблицей
    // universeServiceKinds (dump/subsystem_universe_kinds.go), поле bslCollection; тест
    // dump/subsystem_universe_bslsync_test.go читает этот файл и это проверяет, чтобы
    // живой путь и путь по дампу не разошлись.
    //
    // NEEDS REAL-1C VALIDATION: имена коллекций и метод .ПолноеИмя() не подтверждены
    // исходниками репозитория. Всё под Попытка: неверное имя коллекции ловится ниже и
    // фиксируется в предупреждениях (не молчаливый пропуск), худший случай: часть
    // коллекций пропущена с предупреждением, а не 500. Заметки по несовпадениям (НЕ
    // исправлять): РегламентныеЗадания хранятся под коллекцией РегулярныеЗадания, а
    // .ПолноеИмя() даёт РегламентноеЗадание; WebСервисы лежат в коллекции ВебСервисы.
    ПрикладныеКоллекции = Новый Массив;
    // Прикладные виды (15).
    ПрикладныеКоллекции.Добавить("Справочники");
    ПрикладныеКоллекции.Добавить("Документы");
    ПрикладныеКоллекции.Добавить("Перечисления");
    ПрикладныеКоллекции.Добавить("Отчеты");
    ПрикладныеКоллекции.Добавить("Обработки");
    ПрикладныеКоллекции.Добавить("РегистрыСведений");
    ПрикладныеКоллекции.Добавить("РегистрыНакопления");
    ПрикладныеКоллекции.Добавить("РегистрыБухгалтерии");
    ПрикладныеКоллекции.Добавить("РегистрыРасчета");
    ПрикладныеКоллекции.Добавить("ПланыСчетов");
    ПрикладныеКоллекции.Добавить("ПланыВидовХарактеристик");
    ПрикладныеКоллекции.Добавить("ПланыВидовРасчета");
    ПрикладныеКоллекции.Добавить("ПланыОбмена");
    ПрикладныеКоллекции.Добавить("БизнесПроцессы");
    ПрикладныеКоллекции.Добавить("Задачи");
    // Служебные и прочие виды верхнего уровня, пригодные для состава подсистемы (27).
    ПрикладныеКоллекции.Добавить("Константы");
    ПрикладныеКоллекции.Добавить("ОбщиеМодули");
    ПрикладныеКоллекции.Добавить("ОбщиеФормы");
    ПрикладныеКоллекции.Добавить("ОбщиеКоманды");
    ПрикладныеКоллекции.Добавить("ГруппыКоманд");
    ПрикладныеКоллекции.Добавить("ОбщиеМакеты");
    ПрикладныеКоллекции.Добавить("ОбщиеКартинки");
    ПрикладныеКоллекции.Добавить("ОпределяемыеТипы");
    ПрикладныеКоллекции.Добавить("HTTPСервисы");
    ПрикладныеКоллекции.Добавить("ВебСервисы");
    ПрикладныеКоллекции.Добавить("ПакетыXDTO");
    ПрикладныеКоллекции.Добавить("ПараметрыСеанса");
    ПрикладныеКоллекции.Добавить("РегулярныеЗадания");
    ПрикладныеКоллекции.Добавить("Роли");
    ПрикладныеКоллекции.Добавить("ФункциональныеОпции");
    ПрикладныеКоллекции.Добавить("ПодпискиНаСобытия");
    ПрикладныеКоллекции.Добавить("ЖурналыДокументов");
    ПрикладныеКоллекции.Добавить("ХранилищаНастроек");
    // Финализация до ПОЛНОГО набора видов, пригодных для состава подсистемы (каждый
    // встречается в реальном <Content> вендорских конфигураций). Имена коллекций не
    // подтверждены исходниками репозитория, всё под Попытка (см. заметку выше): неверное
    // имя ловится и фиксируется в предупреждениях, а не роняет ответ. Про нумераторы документов:
    // .ПолноеИмя() даёт НумераторДокументов, коллекция Метаданные.НумераторыДокументов.
    ПрикладныеКоллекции.Добавить("Стили");
    ПрикладныеКоллекции.Добавить("ЭлементыСтиля");
    ПрикладныеКоллекции.Добавить("КритерииОтбора");
    ПрикладныеКоллекции.Добавить("Последовательности");
    ПрикладныеКоллекции.Добавить("ОбщиеРеквизиты");
    ПрикладныеКоллекции.Добавить("НумераторыДокументов");
    ПрикладныеКоллекции.Добавить("WSСсылки");
    ПрикладныеКоллекции.Добавить("ПараметрыФункциональныхОпций");
    ПрикладныеКоллекции.Добавить("ВнешниеИсточникиДанных");

    ВсеОбъекты = Новый Массив;
    Для Каждого ИмяКоллекции Из ПрикладныеКоллекции Цикл
        Попытка
            Коллекция = Метаданные[ИмяКоллекции];
            Для Каждого ОбъектМетаданных Из Коллекция Цикл
                Попытка
                    ВсеОбъекты.Добавить(ОбъектМетаданных.ПолноеИмя());
                Исключение
                КонецПопытки;
            КонецЦикла;
        Исключение
            // NEEDS REAL-1C VALIDATION: применимая коллекция, бросившая при обходе,
            // пропускается, но фиксируется в предупреждениях, чтобы деградировавший
            // (неполный) универсум был виден потребителю, а не молча считался полным.
            Предупреждения.Добавить(ИмяКоллекции + ": " + ОписаниеОшибки());
            Продолжить;
        КонецПопытки;
    КонецЦикла;
    Результат.Вставить("allObjects", ВсеОбъекты);
    Если Предупреждения.Количество() > 0 Тогда
        Результат.Вставить("warnings", Предупреждения);
    КонецЕсли;

    Возврат ОтветJSON(Результат);
КонецФункции

// POST /query
Функция ЗапросPOST(Запрос)
    Параметры = РазобратьJSON(Запрос.ПолучитьТелоКакСтроку());

    ТекстЗапроса = Параметры.query;
    Лимит = 100;
    Если Параметры.Свойство("limit") И Параметры.limit > 0 Тогда
        Лимит = Мин(Параметры.limit, 1000);
    КонецЕсли;

    Префикс = ВРег(СокрЛП(Лев(ТекстЗапроса, 10)));
    Если Лев(Префикс, 7) <> "ВЫБРАТЬ" И Лев(Префикс, 6) <> "SELECT" Тогда
        Возврат ОтветОшибка(400, "Only SELECT queries allowed");
    КонецЕсли;

    Попытка
        Запрос1С = Новый Запрос(ТекстЗапроса);

        Если Параметры.Свойство("parameters") И ТипЗнч(Параметры.parameters) = Тип("Структура") Тогда
            Для Каждого КлючИЗначение Из Параметры.parameters Цикл
                Запрос1С.УстановитьПараметр(КлючИЗначение.Ключ, ПреобразоватьЗначениеПараметра(КлючИЗначение.Значение));
            КонецЦикла;
        КонецЕсли;

        РезультатЗапроса = Запрос1С.Выполнить();
    Исключение
        Возврат ОтветОшибка(400, ОписаниеОшибки());
    КонецПопытки;

    Выборка = РезультатЗапроса.Выбрать();

    Колонки = Новый Массив;
    Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
        Колонки.Добавить(Колонка.Имя);
    КонецЦикла;

    Строки = Новый Массив;
    Счетчик = 0;
    Усечено = Ложь;
    Пока Выборка.Следующий() Цикл
        Если Счетчик >= Лимит Тогда
            Усечено = Истина;
            Прервать;
        КонецЕсли;
        Строка = Новый Массив;
        Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
            Строка.Добавить(ПривестиЗначениеКJSON(Выборка[Колонка.Имя]));
        КонецЦикла;
        Строки.Добавить(Строка);
        Счетчик = Счетчик + 1;
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("columns", Колонки);
    Результат.Вставить("rows", Строки);
    Результат.Вставить("total", Счетчик);
    Результат.Вставить("truncated", Усечено);

    Возврат ОтветJSON(Результат);
КонецФункции

// GET /configuration
Функция КонфигурацияGET(Запрос)
    Результат = Новый Структура;
    Результат.Вставить("name",             Метаданные.Имя);
    Результат.Вставить("version",          Метаданные.Версия);
    Результат.Вставить("vendor",           Метаданные.Поставщик);
    СИ = Новый СистемнаяИнформация;
    Результат.Вставить("platform_version", СИ.ВерсияПриложения);

    РежимИБ = "";
    Попытка
        СтрокаСоединения = СтрокаСоединенияИнформационнойБазы();
        Если СтрНайти(ВРег(СтрокаСоединения), "FILE=") > 0 Тогда
            РежимИБ = "file";
        ИначеЕсли СтрНайти(ВРег(СтрокаСоединения), "SRVR=") > 0 Тогда
            РежимИБ = "server";
        КонецЕсли;
    Исключение
    КонецПопытки;
    Результат.Вставить("mode", РежимИБ);

    Возврат ОтветJSON(Результат);
КонецФункции

// GET /version
Функция ВерсияGET(Запрос)
    Результат = Новый Структура;
    Результат.Вставить("version", "0.4.4");

    Возврат ОтветJSON(Результат);
КонецФункции

// GET /form/{type}/{name}
Функция ФормаGET(Запрос)
    ТипОбъекта = Запрос.ПараметрыURL["type"];
    ИмяОбъекта = Запрос.ПараметрыURL["name"];

    ОбъектМД = НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Возврат ОтветОшибка(404, "Object not found");
    КонецЕсли;

    Форма = ПолучитьОсновнуюФорму(ОбъектМД);
    Если Форма = Неопределено Тогда
        Возврат ОтветОшибка(404, "Form not found");
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("name", Форма.Имя);
    Результат.Вставить("title", Форма.Синоним);

    // Элементы формы (могут быть недоступны в режиме Предприятия)
    Элементы = Новый Массив;
    Попытка
        Для Каждого Элемент Из Форма.Элементы Цикл
            ОписаниеЭлемента = Новый Структура;
            ОписаниеЭлемента.Вставить("name", Элемент.Имя);
            ОписаниеЭлемента.Вставить("type", Строка(ТипЗнч(Элемент)));
            Попытка
                ОписаниеЭлемента.Вставить("title", Элемент.Заголовок);
            Исключение
                ОписаниеЭлемента.Вставить("title", "");
            КонецПопытки;
            Попытка
                ОписаниеЭлемента.Вставить("dataPath", Строка(Элемент.ПутьКДанным));
            Исключение
                ОписаниеЭлемента.Вставить("dataPath", "");
            КонецПопытки;
            Элементы.Добавить(ОписаниеЭлемента);
        КонецЦикла;
    Исключение
    КонецПопытки;
    Результат.Вставить("elements", Элементы);

    // Команды формы (могут быть недоступны в режиме Предприятия)
    Команды = Новый Массив;
    Попытка
        Для Каждого Команда Из Форма.Команды Цикл
            ОписаниеКоманды = Новый Структура;
            ОписаниеКоманды.Вставить("name", Команда.Имя);
            ОписаниеКоманды.Вставить("action", Команда.Действие);
            Команды.Добавить(ОписаниеКоманды);
        КонецЦикла;
    Исключение
    КонецПопытки;
    Результат.Вставить("commands", Команды);

    // Обработчики событий формы
    Обработчики = Новый Массив;
    МассивСобытий = Новый Массив;
    МассивСобытий.Добавить("ПриОткрытии");
    МассивСобытий.Добавить("ПриСозданииНаСервере");
    МассивСобытий.Добавить("ПередЗаписью");
    МассивСобытий.Добавить("ПриЗаписиНаСервере");
    МассивСобытий.Добавить("ПослеЗаписиНаСервере");
    МассивСобытий.Добавить("ПередЗакрытием");
    МассивСобытий.Добавить("ОбработкаОповещения");
    МассивСобытий.Добавить("ОбработкаНавигационнойСсылки");
    МассивСобытий.Добавить("ОбработкаВыбора");

    Для Каждого ИмяСобытия Из МассивСобытий Цикл
        Попытка
            ИмяОбработчика = Форма[ИмяСобытия];
            Если Не ПустаяСтрока(ИмяОбработчика) Тогда
                ОписаниеОбработчика = Новый Структура;
                ОписаниеОбработчика.Вставить("event", ИмяСобытия);
                ОписаниеОбработчика.Вставить("handler", ИмяОбработчика);
                Обработчики.Добавить(ОписаниеОбработчика);
            КонецЕсли;
        Исключение
            Продолжить;
        КонецПопытки;
    КонецЦикла;
    Результат.Вставить("handlers", Обработчики);

    Возврат ОтветJSON(Результат);
КонецФункции

// POST /validate-query
Функция ПроверкаЗапросаPOST(Запрос)
    Параметры = РазобратьJSON(Запрос.ПолучитьТелоКакСтроку());

    ТекстЗапроса = Параметры.query;
    Если ПустаяСтрока(ТекстЗапроса) Тогда
        Возврат ОтветОшибка(400, "query is required");
    КонецЕсли;

    Ошибки = Новый Массив;

    Попытка
        СхемаЗапроса = Новый СхемаЗапроса;
        СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
        СхемаЗапроса.ПолучитьТекстЗапроса();

        Результат = Новый Структура;
        Результат.Вставить("valid", Истина);
        Результат.Вставить("errors", Ошибки);
    Исключение
        Результат = Новый Структура;
        Результат.Вставить("valid", Ложь);
        Ошибки.Добавить(ОписаниеОшибки());
        Результат.Вставить("errors", Ошибки);
    КонецПопытки;

    Возврат ОтветJSON(Результат);
КонецФункции

// POST /eventlog
Функция ЖурналРегистрацииPOST(Запрос)
    Попытка
        Параметры = РазобратьJSON(Запрос.ПолучитьТелоКакСтроку());
    Исключение
        Параметры = Новый Структура;
    КонецПопытки;

    Отбор = Новый Структура;

    Если Параметры.Свойство("start_date") И ЗначениеЗаполнено(Параметры.start_date) Тогда
        Попытка
            Отбор.Вставить("ДатаНачала", XMLЗначение(Тип("Дата"), Параметры.start_date));
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если Параметры.Свойство("end_date") И ЗначениеЗаполнено(Параметры.end_date) Тогда
        Попытка
            Отбор.Вставить("ДатаОкончания", XMLЗначение(Тип("Дата"), Параметры.end_date));
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если Параметры.Свойство("level") И ЗначениеЗаполнено(Параметры.level) Тогда
        СоответствиеУровней = Новый Соответствие;
        СоответствиеУровней.Вставить("Ошибка",        УровеньЖурналаРегистрации.Ошибка);
        СоответствиеУровней.Вставить("Предупреждение", УровеньЖурналаРегистрации.Предупреждение);
        СоответствиеУровней.Вставить("Информация",     УровеньЖурналаРегистрации.Информация);
        СоответствиеУровней.Вставить("Примечание",     УровеньЖурналаРегистрации.Примечание);
        Уровень = СоответствиеУровней[Параметры.level];
        Если Уровень <> Неопределено Тогда
            МассивУровней = Новый Массив;
            МассивУровней.Добавить(Уровень);
            Отбор.Вставить("Уровень", МассивУровней);
        КонецЕсли;
    КонецЕсли;

    Если Параметры.Свойство("user") И ЗначениеЗаполнено(Параметры.user) Тогда
        Попытка
            ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(Параметры.user);
            Если ПользовательИБ <> Неопределено Тогда
                МассивПользователей = Новый Массив;
                МассивПользователей.Добавить(ПользовательИБ);
                Отбор.Вставить("Пользователь", МассивПользователей);
            КонецЕсли;
        Исключение
            // Нет права Администрирование — фильтр по пользователю не применяется
        КонецПопытки;
    КонецЕсли;

    Лимит = 50;
    Если Параметры.Свойство("limit") И Параметры.limit > 0 Тогда
        Лимит = Мин(Параметры.limit, 500);
    КонецЕсли;

    // Защита от OOM: если не указана дата начала, ограничиваем последними 7 днями
    Если НЕ Отбор.Свойство("ДатаНачала") Тогда
        Отбор.Вставить("ДатаНачала", ТекущаяДата() - 7 * 86400);
    КонецЕсли;

    ТаблицаЖурнала = Новый ТаблицаЗначений;
    ВыгрузитьЖурналРегистрации(ТаблицаЖурнала, Отбор);

    ВсегоЗаписей = ТаблицаЖурнала.Количество();

    МассивСобытий = Новый Массив;
    Для Индекс = 0 По Мин(Лимит, ВсегоЗаписей) - 1 Цикл
        Строка = ТаблицаЖурнала[Индекс];
        Событие = Новый Структура;
        Событие.Вставить("date",        XMLСтрока(Строка.Дата));
        Событие.Вставить("level",       Строка(Строка.Уровень));
        Событие.Вставить("event",       Строка(Строка.Событие));
        Событие.Вставить("user",        Строка(Строка.ИмяПользователя));
        Событие.Вставить("computer",    Строка(Строка.Компьютер));
        Событие.Вставить("metadata",    ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "МетаданныеПредставление"));
        Событие.Вставить("data",        ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "ДанныеПредставление"));
        Событие.Вставить("comment",     ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "Комментарий"));
        Событие.Вставить("transaction", ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "ИдентификаторТранзакции"));
        МассивСобытий.Добавить(Событие);
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("events", МассивСобытий);
    Результат.Вставить("total",  ВсегоЗаписей);

    Возврат ОтветJSON(Результат);
КонецФункции

Функция ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, ИмяКолонки)
    Если ТаблицаЖурнала.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Возврат Строка(Строка[ИмяКолонки]);
КонецФункции

// GET /extensions — возвращает бинарные данные (.cfe) всех расширений в base64
Функция РасширенияGET(Запрос)
    Результат = Новый Массив;

    Попытка
        МассивРасширений = РасширенияКонфигурации.Получить();
    Исключение
        Возврат ОтветJSON(Результат);
    КонецПопытки;

    Для Каждого Расширение Из МассивРасширений Цикл
        Попытка
            Данные = Расширение.ПолучитьДанные();
            ОписаниеРасш = Новый Структура;
            ОписаниеРасш.Вставить("name", Расширение.Имя);
            ОписаниеРасш.Вставить("data", Base64Строка(Данные));
            Результат.Добавить(ОписаниеРасш);
        Исключение
        КонецПопытки;
    КонецЦикла;

    Возврат ОтветJSON(Результат);
КонецФункции
